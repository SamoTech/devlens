# GitHub OAuth (NextAuth)
AUTH_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# Server-side GitHub token (increases rate limit to 5000/hr)
# Required for: Dependabot, Secret Scanning, Code Scanning, Advisory DB
GITHUB_TOKEN=

# Upstash Redis — for caching + real trend history
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# NIST NVD API Key — free, raises rate limit from 5 req/30s → 50 req/30s
# Register at: https://nvd.nist.gov/developers/request-an-api-key
# Optional — scanner works without it, just slower on NVD lookups
NVD_API_KEY=
