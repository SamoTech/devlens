# GitHub OAuth App (create at github.com/settings/developers)
AUTH_GITHUB_ID=your-github-oauth-app-id
AUTH_GITHUB_SECRET=your-github-oauth-app-secret
AUTH_SECRET=your-random-32-char-secret

# GitHub Token for higher API rate limit (optional, used as fallback)
GITHUB_TOKEN=ghp_your-token-here

NEXTAUTH_URL=http://localhost:3000

# Upstash Redis (https://upstash.com — free tier works)
# Used for: response caching (5min TTL) + real trend history
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
